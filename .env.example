# Copy to .env and fill in values
# Server
PORT=3002
NODE_ENV=development

# eBay
EBAY_ENV=sandbox
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Optional: application token scopes (space-separated) – can be omitted
EBAY_APP_SCOPES=

# Optional: user auth bits (for future Sell flows that require seller consent)
EBAY_RUNAME=
EBAY_USER_SCOPES=
EBAY_REFRESH_TOKEN=
