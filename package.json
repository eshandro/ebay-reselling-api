  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --dts --out-dir dist --clean",
    "start": "node dist/server.js",
    "lint": "eslint .",
