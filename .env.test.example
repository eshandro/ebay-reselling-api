# .env.test.example - Template for test environment variables

# Environment Settings
NODE_ENV=test
PORT=3002
LOG_LEVEL=fatal  # Reduce noise during test runs

# eBay Configuration (Mock Values)
EBAY_ENV=sandbox
EBAY_CLIENT_ID=test-client-id-123
EBAY_CLIENT_SECRET=test-client-secret-abc
EBAY_RUNAME=test-runame-xyz
EBAY_APP_SCOPES=https://api.ebay.com/oauth/api_scope
EBAY_USER_SCOPES=https://api.ebay.com/oauth/api_scope/sell.inventory
EBAY_REFRESH_TOKEN=mock-refresh-token
